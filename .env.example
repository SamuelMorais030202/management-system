# Variáveis de ambiente para Vite
# No Vite, as variáveis de ambiente devem começar com VITE_ para serem expostas ao código do cliente
# Copie este arquivo para .env e preencha com os valores corretos

# URL base da API
VITE_BASE_URL=https://api.unisystem.ddns.com.br/orion/v1
# VITE_BASE_URL=/api

# URL do WebSocket para KDS (Kitchen Display System)
VITE_KDS_WS_URL=ws://179.127.4.150:8100
# VITE_KDS_WS_URL=/ws